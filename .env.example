# JWT
JWT_SECRET=your-very-secure-jwt-secret-at-least-32-characters

# Database
# Use one of the following:
# 1) Postgres / Neon
DATABASE_URL=postgresql://user:password@host:5432/database

# 2) Turso libSQL
# TURSO_DATABASE_URL=https://your-turso-database-url
# TURSO_AUTH_TOKEN=your-turso-auth-token

# Notes:
# - If DATABASE_URL is set and begins with "postgres", the app uses Postgres.
# - If TURSO_DATABASE_URL is set, the app uses Turso.
# - If neither is set, the app falls back to a local SQLite database in storage/learnhub.db.

# Razorpay
RAZORPAY_KEY_ID=rzp_test_your_public_key
RAZORPAY_KEY_SECRET=your_razorpay_secret_key
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_public_key
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
